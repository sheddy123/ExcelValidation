root = true

[*.cs]
indent_style = space
indent_size = 4
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

# The whole point of ExcelCellType is to name the types a column can hold, so members called
# Integer / Decimal / Double / Long / Guid are the clearest possible names rather than a smell.
dotnet_diagnostic.CA1720.severity = none

# ArgumentNullException.ThrowIfNull does not exist on netstandard2.0, which this package targets.
dotnet_diagnostic.CA1510.severity = none

[*.{csproj,props,targets}]
indent_style = space
indent_size = 2

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
